local Modules = {
    Colors = {
        ["Green"] = "0,255,0",
        ["Cyan"] = "33,161,163",
        ["Red"] = "255,0,0",
        ["Blue"] = "0,0,255",
        ["Yellow"] = "255,255,0",
        ["Purple"] = "128,0,128",
        ["Orange"] = "255,165,0",
        ["Pink"] = "255,192,203",
        ["White"] = "255,255,255",
        ["Gray"] = "128,128,128"
    }
}

local function color3ToRgbString(color)
    if type(color) == "Color3" then
        return string.format("%d,%d,%d", color.R * 255, color.G * 255, color.B * 255)
    end
    return tostring(color)
end

local function getConsoleText()
    local console = game:GetService("CoreGui"):FindFirstChild("DevConsoleMaster")
    if not console then return nil end
    local window = console:FindFirstChild("DevConsoleWindow")
    if not window then return nil end
    local ui = window:FindFirstChild("DevConsoleUI")
    if not ui then return nil end
    
    local mainView = ui:FindFirstChild("MainView")
    if mainView then
        return mainView:FindFirstChild("ClientLog")
    end
    return ui:FindFirstChild("ClientLog")
end

local function cprint(value, color)
    local colorString
    
    if type(color) == "Color3" then
        colorString = color3ToRgbString(color)
    elseif type(color) == "string" and Modules.Colors[color] then
        colorString = Modules.Colors[color]
    else
        colorString = "255,255,255"
    end
    
    local clientLog = getConsoleText()
    if not clientLog then
        print(value)
        return
    end
    
    local coloredText = '<font color="rgb(' .. colorString .. ')">' .. value .. '</font>'
    
    local originalPrint = print
    print = function(...)
        local args = {...}
        for i, arg in ipairs(args) do
            if type(arg) == "string" and arg == value then
                args[i] = coloredText
            end
        end
        originalPrint(unpack(args))
    end
    
    originalPrint(value)
    print = originalPrint
end

local function init()
    local console = game:GetService("CoreGui"):FindFirstChild("DevConsoleMaster")
    if console then
        for _, v in pairs(console:GetDescendants()) do
            if v:IsA("TextLabel") then
                v.RichText = true
            end
        end
    end
end

init()

return cprint
