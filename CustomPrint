local Modules = {
    Colors = {
        ["Green"] = "0,255,0",
        ["Cyan"] = "33,161,163",
        ["Red"] = "255,0,0",
        ["Blue"] = "0,0,255",
        ["Yellow"] = "255,255,0",
        ["Purple"] = "128,0,128",
        ["Orange"] = "255,165,0",
        ["Pink"] = "255,192,203",
        ["White"] = "255,255,255",
        ["Gray"] = "128,128,128"
    }
}

local function rgbToString(rgb)
    if type(rgb) == "Color3" then
        return string.format("%d,%d,%d", rgb.R * 255, rgb.G * 255, rgb.B * 255)
    end
    return tostring(rgb)
end

local function getConsoleText()
    local console = game:GetService("CoreGui"):FindFirstChild("DevConsoleMaster")
    if not console then return nil end
    local window = console:FindFirstChild("DevConsoleWindow")
    if not window then return nil end
    local ui = window:FindFirstChild("DevConsoleUI")
    if not ui then return nil end
    
    local mainView = ui:FindFirstChild("MainView")
    if mainView then
        return mainView:FindFirstChild("ClientLog")
    end
    return ui:FindFirstChild("ClientLog")
end

local function colorizeMessage(msgLabel, color, textValue)
    if not msgLabel or not msgLabel:IsA("TextLabel") then return false end
    
    local colorString = rgbToString(color)
    
    local fullText = msgLabel.Text
    local pattern = "(%[%d+:%d+:%d+%])(.-)(%-%-.*)"
    local timeStamp, originalText, marker = string.match(fullText, pattern)
    
    if timeStamp and marker then
        local coloredTime = '<font color="rgb(' .. colorString .. ')">' .. timeStamp .. '</font>'
        local coloredMarker = '<font color="rgb(' .. colorString .. ')">--</font>'
        local newMarker = string.gsub(marker, "%-%-", coloredMarker)
        msgLabel.Text = coloredTime .. originalText .. newMarker .. " " .. textValue
        msgLabel.RichText = true
        return true
    end
    return false
end

local function cprint(value, color)
    local colorName = color
    local colorString
    
    if type(color) == "Color3" then
        colorString = rgbToString(color)
    elseif type(color) == "string" and Modules.Colors[color] then
        colorString = Modules.Colors[color]
        colorName = color
    else
        colorString = "255,255,255"
        colorName = "White"
    end
    
    local id = string.format("%d.%d", os.time(), math.random(1e8, 9e8))
    local marker = "--" .. id
    
    local clientLog = getConsoleText()
    if not clientLog then
        print(value)
        return
    end
    
    local function tryColorize(msgLabel)
        if not msgLabel then return false end
        local text = msgLabel.Text
        if not string.find(text, marker) then return false end
        return colorizeMessage(msgLabel, colorString, value)
    end
    
    for _, child in ipairs(clientLog:GetChildren()) do
        local msg = child:FindFirstChild("msg")
        if tryColorize(msg) then break end
    end
    
    local connection
    connection = clientLog.ChildAdded:Connect(function(child)
        local msg = child:FindFirstChild("msg")
        if tryColorize(msg) then
            connection:Disconnect()
        end
    end)
    
    print(marker .. " " .. value)
end

local function init()
    local console = game:GetService("CoreGui"):FindFirstChild("DevConsoleMaster")
    if console then
        for _, v in pairs(console:GetDescendants()) do
            if v:IsA("TextLabel") then
                v.RichText = true
            end
        end
    end
    
    game:GetService("RunService").Heartbeat:Connect(function()
        local consoleCheck = game:GetService("CoreGui"):FindFirstChild("DevConsoleMaster")
        if consoleCheck then
            for _, v in pairs(consoleCheck:GetDescendants()) do
                if v:IsA("TextLabel") and not v.RichText then
                    v.RichText = true
                end
            end
        end
    end)
end

init()

return cprint
